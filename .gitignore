# --- ML Model Artifacts & Data ---
# --- ML Model Artifacts & Data ---
# We ignore everything in these folders except the .gitkeep file
# This ensures the folder structure is preserved in Git without the large binaries.
models/*
!models/.gitkeep

data/*
!data/.gitkeep

# --- Evaluation Outputs ---
evaluation/*
!evaluation/.gitkeep


